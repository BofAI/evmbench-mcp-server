# Non-sensitive defaults (safe to commit).
# For production: use as .env and provide secrets via up-production.sh export.
# For local dev: copy to .env and add dev placeholders (POSTGRES_PASSWORD, etc.) if needed.

BACKEND_DEV=false
BACKEND_WEB_HOST='127.0.0.1'
BACKEND_WEB_PORT=1337
BACKEND_WEB_WORKERS=4

POSTGRES_USER='evmbench'
POSTGRES_DB='evmbench'

RABBITMQ_USER='evmbench'
RABBITMQ_PORT=5672
RABBITMQ_QUEUE='instancer.jobs'

BACKEND_SECRETS_BACKEND='http'
# Token is set by compose from host env (up-production.sh) in production.
BACKEND_SECRETS_BACKEND_ARGUMENTS='{"url":"http://secretsvc:8081","token":"__SET_BY_SCRIPT_OR_COMPOSE__"}'

SECRETSVC_HOST='127.0.0.1'
SECRETSVC_PORT=8081
SECRETSVC_WORKERS=1

RESULTSVC_PORT=8083

BACKEND_OAI_KEY_MODE=proxy
BACKEND_USE_PROXY_STATIC_KEY=true
OAI_PROXY_BASE_URL='http://oai.loc:8084'
